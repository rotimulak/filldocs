#!/bin/bash
# Pre-commit hook - runs tests and linting before commit

set -e

echo "🔍 Running pre-commit checks..."

# Check if we're in the project root
if [ ! -f "package.json" ]; then
  echo "❌ Must run from project root"
  exit 1
fi

# Extract issue ID from branch name
BRANCH=$(git rev-parse --abbrev-ref HEAD)
ISSUE_ID=$(echo $BRANCH | grep -oP 'ROT-\d+' || echo "")

if [ -z "$ISSUE_ID" ]; then
  echo "⚠️  Warning: Branch name doesn't contain issue ID (ROT-XXX)"
  echo "   Consider renaming branch to include issue ID"
fi

# Backend checks
if [ -d "backend" ]; then
  echo ""
  echo "🐍 Backend checks..."

  cd backend

  # Check if there are Python files to check
  PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || echo "")

  if [ -n "$PYTHON_FILES" ]; then
    echo "  → Format check (black)..."
    python -m black --check $PYTHON_FILES || {
      echo "❌ Black formatting failed. Run: black backend/"
      exit 1
    }

    echo "  → Lint check (ruff)..."
    python -m ruff check $PYTHON_FILES || {
      echo "❌ Ruff linting failed. Run: ruff check backend/ --fix"
      exit 1
    }

    echo "  → Type check (mypy)..."
    python -m mypy $PYTHON_FILES || {
      echo "⚠️  Type checking found issues (not blocking)"
    }

    echo "  → Running tests..."
    python -m pytest tests/ -q || {
      echo "❌ Tests failed. Fix tests before committing."
      exit 1
    }
  fi

  cd ..
fi

# Frontend checks
if [ -d "frontend" ]; then
  echo ""
  echo "⚛️  Frontend checks..."

  cd frontend

  # Check if there are JS/TS files to check
  JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx)$' || echo "")

  if [ -n "$JS_FILES" ]; then
    echo "  → Lint check..."
    npm run lint || {
      echo "❌ ESLint failed. Run: npm run lint -- --fix"
      exit 1
    }

    echo "  → Type check..."
    npm run type-check || {
      echo "⚠️  Type checking found issues (not blocking)"
    }

    echo "  → Running tests..."
    npm test -- --watchAll=false --passWithNoTests || {
      echo "❌ Tests failed. Fix tests before committing."
      exit 1
    }
  fi

  cd ..
fi

echo ""
echo "✅ All pre-commit checks passed!"

# Auto-add issue ID to commit message if not present
COMMIT_MSG_FILE="$1"
if [ -n "$ISSUE_ID" ] && [ -n "$COMMIT_MSG_FILE" ]; then
  COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
  if ! echo "$COMMIT_MSG" | grep -q "$ISSUE_ID"; then
    echo ""
    echo "💡 Tip: Add $ISSUE_ID to your commit message for Linear integration"
  fi
fi

exit 0
